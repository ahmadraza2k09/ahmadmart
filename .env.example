# Ahmad Mart — environment variable template.
# Copy this file to `.env` (git-ignored) and fill in real values for local
# `vercel dev`. In production, set the same variables in Vercel → Settings →
# Environment Variables.

# Neon Postgres connection string (keep ?sslmode=require).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Long random string used to sign login tokens, e.g. `openssl rand -hex 32`.
JWT_SECRET="change-me-to-a-long-random-string"

# Admin account (auto-created in the users table on first login).
ADMIN_EMAIL="ahmadmart@mail.com"
ADMIN_PASSWORD="change-me"
